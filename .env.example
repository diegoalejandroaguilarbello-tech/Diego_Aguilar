# Copia este archivo como .env.local y reemplaza únicamente los valores locales.
# Nunca escribas aquí la contraseña administrativa en texto plano.
ADMIN_USERNAME=elige-un-usuario
ADMIN_PASSWORD_HASH=$2b$12$reemplaza-con-el-hash-generado
SECURITY_HASH_SALT=reemplaza-con-el-salt-generado

# Duración de la sesión y protección de acceso.
ADMIN_SESSION_HOURS=8
ADMIN_IDLE_TIMEOUT_MINUTES=30
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_WINDOW_MINUTES=15

# Cloudflare Turnstile. La clave secreta solo debe existir en variables privadas.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=tu-clave-publica
TURNSTILE_SECRET_KEY=tu-clave-secreta

# Avisos de nuevas cotizaciones. RESEND_API_KEY siempre debe ser privada.
RESEND_API_KEY=re_xxxxxxxxx
LEAD_NOTIFICATION_EMAIL=tu-correo@ejemplo.com
LEAD_FROM_EMAIL="Cotizaciones <onboarding@resend.dev>"
